# Langfuse Cloud (free Hobby tier) — get keys at https://cloud.langfuse.com
#   Project Settings -> API Keys -> Create.
# Copy this file to .env (which is gitignored) and fill in your keys.
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx

# Region URL. EU: https://cloud.langfuse.com   |   US: https://us.cloud.langfuse.com
# LANGFUSE_BASE_URL is the canonical var (langfuse v4 SDK + langfuse-cli). The gateway
# derives LiteLLM's LANGFUSE_OTEL_HOST from it, so this one line is enough.
LANGFUSE_BASE_URL=https://cloud.langfuse.com
